generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  active    Boolean  @default(true)
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
}

model Faculty {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  deanName String    @default("Sin asignar")
  address  String?
  email    String?
  phone    String?
  programs Program[]
}

model Program {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  directorName String   @default("Sin asignar")
  address      String?
  email        String?
  phone        String?
  facultyId    Int
  faculty      Faculty  @relation(fields: [facultyId], references: [id])
  persons      Person[]
}

model Person {
  id             Int                     @id @default(autoincrement())
  firstName      String
  lastName       String
  idType         String
  identification String                  @unique
  phone          String?
  email          String
  programId      Int?
  program        Program?                @relation(fields: [programId], references: [id])
  assignments    CertificateAssignment[]
  createdAt      DateTime                @default(now())
}

model Event {
  id           Int           @id @default(autoincrement())
  name         String
  startDate    DateTime
  endDate      DateTime
  description  String?       @db.Text
  eventType    String
  status       String        @default("Realizado")
  certificates Certificate[]
  createdAt    DateTime      @default(now())
}

model Certificate {
  id                Int                     @id @default(autoincrement())
  participationType String
  templateHtml      String                  @db.LongText
  eventId           Int
  event             Event                   @relation(fields: [eventId], references: [id])
  issueDate         DateTime
  assignments       CertificateAssignment[]
  createdAt         DateTime                @default(now())
}

model CertificateAssignment {
  id            Int         @id @default(autoincrement())
  certificateId Int
  certificate   Certificate @relation(fields: [certificateId], references: [id])
  personId      Int
  person        Person      @relation(fields: [personId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([certificateId, personId])
}
